//
//      a comment
//
:star 42 raw.write ;
:pling 33 raw.write ;
:plus 43 raw.write ;
:cr  [[ 13 raw.write ]] ;
:bar 10 for star cr ;
:box 4 for bar ;

:count variable 

:body i raw.hex case 2 star 4 plus otherwise pling endcase  cr ;

:set.address [ $9F20 ! c>a $9F22 c! ] ;

:clear.line 310 for [ i $9f23 c! ] ;

:main   

    $21 $9f29 c!
    64 $9f2a c!
    64 $9f2b c!
    $11 , $FA00 set.address 

    $07 $9F34 c!
    $00 $9F36 c!

    10 for [ $10 , i 320 * set.address clear.line ]
    65000 for [ ]
    10 for [ $10 , i 100 + 320 * set.address clear.line ]
    repeat 0
;
