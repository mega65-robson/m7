//
//      a comment
//
:star 42 raw.write ;
:pling 33 raw.write ;
:plus 43 raw.write ;
:cr  [[ 13 raw.write ]] ;
:bar 10 for star cr ;
:box 4 for bar ;

:count variable 

:body i raw.hex case 2 star 4 plus otherwise pling endcase  cr ;

:main   
    raw.hex cr
    star cr
    box 
    count raw.hex cr
    & count raw.hex cr
    $FEDC -> count 
    count raw.hex cr
    pling cr 
    // 32 for [ 64 i + raw.write ] cr
    bye
;
