; ************************************************************************************************
;
;                                       Break to debugger
;
; ************************************************************************************************

debug   .macro
        .byte   $DB
        .endm

; ************************************************************************************************
;
;                               Bytecode / Codeword markers
;
; ************************************************************************************************

bytecode .macro
        .endm

codeword .macro
        .align  2
        nop
        .endm

; ************************************************************************************************
;
;                                       Copy A to B using Y
;
; ************************************************************************************************

copyAB  .macro
        lda     aRegister
        sta     bRegister
        lda     aRegister+1
        sta     bRegister+1
        .endm

; ************************************************************************************************
;
;                           Code shortens for binary operation
;
; ************************************************************************************************

binop   .macro
        lda     bRegister
        \1     aRegister
        sta     aRegister        
        lda     bRegister+1
        \1     aRegister+1
        sta     aRegister+1
        rts
        .endm

; ************************************************************************************************
;
;                                   Word increment/decrement
;
; ************************************************************************************************

incword .macro
        inc     0+(\1)
        bne     _NoCarry
        inc     1+(\1)
_NoCarry:
        .endm

decword .macro                        
        lda     0+(\1)
        bne     _NoBorrow
        dec     1+(\1)
_NoBorrow:
        dec     0+(\1)
        .endm
        
; ************************************************************************************************
;
;                               Push data off/on temporary stack
;
; ************************************************************************************************

stackopen .macro
        ldx     tempStackPtr
        .endm

stackclose .macro
        stx     tempStackPtr
        .endm

rpush   .macro
        lda     \1
        sta     tempStack,x
        lda     1+\1
        sta     tempStack+1,x
        inx
        inx
        .endm

rpop    .macro
        dex
        dex
        lda     tempStack,x
        sta     \1
        lda     tempStack+1,x
        sta     1+\1
        .endm

